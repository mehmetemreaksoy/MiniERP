@model Sale

@{
    ViewData["Title"] = "Delete Sale";
}

<h1>Delete Sale</h1>

<p>Are you sure you want to delete this sale?</p>

<dl class="row">
    <dt class="col-sm-2">Customer</dt>
    <dd class="col-sm-10">@Model.Customer?.Name</dd>

    <dt class="col-sm-2">Product</dt>
    <dd class="col-sm-10">@Model.Product?.Name</dd>

    <dt class="col-sm-2">Quantity</dt>
    <dd class="col-sm-10">@Model.Quantity</dd>

    <dt class="col-sm-2">Unit Price</dt>
    <dd class="col-sm-10">@Model.UnitPrice</dd>

    <dt class="col-sm-2">Total Price</dt>
    <dd class="col-sm-10">@Model.TotalPrice</dd>

    <dt class="col-sm-2">Sale Date</dt>
    <dd class="col-sm-10">@Model.SaleDate.ToShortDateString()</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>
