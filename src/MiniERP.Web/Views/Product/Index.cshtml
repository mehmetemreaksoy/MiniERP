@using Microsoft.AspNetCore.Mvc.Rendering
@model List<Product>

@{
    ViewData["Title"] = "Ürünler";
}

<div class="list-page-header justify-content-end">
    <div class="d-flex gap-2">
        <a asp-action="Passive" class="btn btn-outline-secondary">Pasif Ürünler</a>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createProductModal">Yeni Ekle</button>
    </div>
</div>

<div class="panel-card">
    <div class="table-responsive">
        <table class="table erp-table mb-0">
            <thead>
                <tr>
                    <th>Ürün Adı</th>
                    <th>Kategori</th>
                    <th>Fiyat</th>
                    <th>Stok</th>
                    <th>Kritik Stok</th>
                    <th>Oluşturma Tarihi</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td><strong>@product.Name</strong></td>
                        <td>@product.Category?.Name</td>
                        <td>@product.Price.ToString("N2")</td>
                        <td>
                            <span class="status-pill @(product.StockQuantity <= product.CriticalStockLevel ? "danger" : "success")">
                                @product.StockQuantity
                            </span>
                        </td>
                        <td>@product.CriticalStockLevel</td>
                        <td>@product.CreatedDate.ToShortDateString()</td>
                        <td class="text-end">
                            <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editProductModal-@product.Id">Düzenle</button>
                            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteProductModal-@product.Id">Sil</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="createProductModal" tabindex="-1" aria-labelledby="createProductModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="createProductModalLabel">Yeni Ürün</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="productCreateName" class="form-label">Ürün Adı</label>
                            <input id="productCreateName" name="Name" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label for="productCreateCategory" class="form-label">Kategori</label>
                            <select id="productCreateCategory" name="CategoryId" class="form-select">
                                <option value="">Kategori seçin</option>
                                @foreach (SelectListItem category in ViewBag.Categories)
                                {
                                    <option value="@category.Value">@category.Text</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label for="productCreatePrice" class="form-label">Fiyat</label>
                            <input id="productCreatePrice" name="Price" class="form-control" type="text" inputmode="decimal" autocomplete="off" />
                        </div>

                        <div class="col-md-4">
                            <label for="productCreateStock" class="form-label">Stok</label>
                            <input id="productCreateStock" name="StockQuantity" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label for="productCreateCriticalStock" class="form-label">Kritik Stok</label>
                            <input id="productCreateCriticalStock" name="CriticalStockLevel" class="form-control" />
                        </div>

                        <div class="col-12">
                            <label for="productCreateDescription" class="form-label">Açıklama</label>
                            <textarea id="productCreateDescription" name="Description" class="form-control"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@foreach (var product in Model)
{
    <div class="modal fade" id="editProductModal-@product.Id" tabindex="-1" aria-labelledby="editProductModalLabel-@product.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <form asp-action="Edit" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title" id="editProductModalLabel-@product.Id">Ürün Düzenle</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="Id" value="@product.Id" />
                        <input type="hidden" name="CreatedDate" value="@product.CreatedDate" />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="productName-@product.Id" class="form-label">Ürün Adı</label>
                                <input id="productName-@product.Id" name="Name" class="form-control" value="@product.Name" />
                            </div>

                            <div class="col-md-6">
                                <label for="productCategory-@product.Id" class="form-label">Kategori</label>
                                <select id="productCategory-@product.Id" name="CategoryId" class="form-select">
                                    @foreach (SelectListItem category in ViewBag.Categories)
                                    {
                                        <option value="@category.Value" selected="@(category.Value == product.CategoryId.ToString() ? "selected" : null)">@category.Text</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label for="productPrice-@product.Id" class="form-label">Fiyat</label>
                                <input id="productPrice-@product.Id" name="Price" class="form-control" type="text" inputmode="decimal" autocomplete="off" value="@product.Price.ToString("N2")" />
                            </div>

                            <div class="col-md-4">
                                <label for="productStock-@product.Id" class="form-label">Stok</label>
                                <input id="productStock-@product.Id" name="StockQuantity" class="form-control" value="@product.StockQuantity" />
                            </div>

                            <div class="col-md-4">
                                <label for="productCriticalStock-@product.Id" class="form-label">Kritik Stok</label>
                                <input id="productCriticalStock-@product.Id" name="CriticalStockLevel" class="form-control" value="@product.CriticalStockLevel" />
                            </div>

                            <div class="col-12">
                                <label for="productDescription-@product.Id" class="form-label">Açıklama</label>
                                <textarea id="productDescription-@product.Id" name="Description" class="form-control">@product.Description</textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="deleteProductModal-@product.Id" tabindex="-1" aria-labelledby="deleteProductModalLabel-@product.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="Delete" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title" id="deleteProductModalLabel-@product.Id">Ürün Sil</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="id" value="@product.Id" />
                        <p class="mb-1">Bu ürünü silmek istediğinize emin misiniz?</p>
                        <strong>@product.Name</strong>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                        <button type="submit" class="btn btn-danger">Sil</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
