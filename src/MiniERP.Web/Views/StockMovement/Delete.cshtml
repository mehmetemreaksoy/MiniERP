@model StockMovement

@{
    ViewData["Title"] = "Delete Stock Movement";
}

<h1>Delete Stock Movement</h1>

<p>Are you sure you want to delete this stock movement?</p>

<dl class="row">
    <dt class="col-sm-2">Product</dt>
    <dd class="col-sm-10">@Model.Product?.Name</dd>

    <dt class="col-sm-2">Movement Type</dt>
    <dd class="col-sm-10">@Model.MovementType</dd>

    <dt class="col-sm-2">Quantity</dt>
    <dd class="col-sm-10">@Model.Quantity</dd>

    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>

    <dt class="col-sm-2">Movement Date</dt>
    <dd class="col-sm-10">@Model.MovementDate.ToShortDateString()</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>
