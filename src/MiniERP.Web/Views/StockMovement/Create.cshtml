@model StockMovement

@{
    ViewData["Title"] = "Create Stock Movement";
}

<h1>Create Stock Movement</h1>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="ProductId" class="form-label">Product</label>
        <select asp-for="ProductId" asp-items="ViewBag.Products" class="form-select">
            <option value="">Select Product</option>
        </select>
        <span asp-validation-for="ProductId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MovementType" class="form-label">Movement Type</label>
        <select asp-for="MovementType" asp-items="ViewBag.MovementTypes" class="form-select">
            <option value="">Select Movement Type</option>
        </select>
        <span asp-validation-for="MovementType" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Quantity" class="form-label"></label>
        <input asp-for="Quantity" class="form-control" />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
