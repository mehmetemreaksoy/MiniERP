<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MiniERP</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MiniERP.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="erp-shell">
        <aside class="erp-sidebar">
            <a class="erp-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="erp-brand-mark">M</span>
                <span>
                    <strong>MiniERP</strong>
                    <small>Automotive</small>
                </span>
            </a>

            <nav class="erp-nav">
                <a asp-area="" asp-controller="Home" asp-action="Index">Ana Panel</a>
                <a asp-area="" asp-controller="Category" asp-action="Index">Kategoriler</a>
                <a asp-area="" asp-controller="Product" asp-action="Index">Ürünler</a>
                <a asp-area="" asp-controller="Customer" asp-action="Index">Cariler</a>
                <a asp-area="" asp-controller="Supplier" asp-action="Index">Tedarikçiler</a>
                <a asp-area="" asp-controller="StockMovement" asp-action="Index">Stok Hareketleri</a>
                <a asp-area="" asp-controller="Sale" asp-action="Index">Satışlar</a>
                <a asp-area="" asp-controller="SalesInvoice" asp-action="Index">Satış Faturaları</a>
                <a asp-area="" asp-controller="Purchase" asp-action="Index">Satın Almalar</a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-area="" asp-controller="AuditLog" asp-action="Index">İşlem Geçmişi</a>
                }
            </nav>
        </aside>

        <div class="erp-main">
            <header class="erp-topbar">
                <div>
                    <p class="erp-eyebrow mb-1">Operations Console</p>
                    <h1 class="erp-page-title">@ViewData["Title"]</h1>
                </div>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="erp-user">
                        <span class="erp-user-dot"></span>
                        @(User.Identity.Name ?? "Admin")
                        <a asp-controller="Account" asp-action="Logout" class="erp-auth-link">Çıkış Yap</a>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="erp-login-link">Login</a>
                }
            </header>

            <main role="main" class="erp-content">
                @RenderBody()
            </main>

            <footer class="erp-footer">
                MiniERP Admin Panel
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
