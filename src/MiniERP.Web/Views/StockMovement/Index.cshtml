@using Microsoft.AspNetCore.Mvc.Rendering
@model List<StockMovement>

@{
    ViewData["Title"] = "Stok Hareketleri";
}

<div class="list-page-header justify-content-end">
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createStockMovementModal">Yeni Ekle</button>
</div>

<div class="panel-card">
    <div class="table-responsive">
        <table class="table erp-table mb-0">
            <thead>
                <tr>
                    <th>Ürün</th>
                    <th>Hareket Tipi</th>
                    <th>Miktar</th>
                    <th>Açıklama</th>
                    <th>Hareket Tarihi</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var stockMovement in Model)
                {
                    <tr>
                        <td><strong>@stockMovement.Product?.Name</strong></td>
                        <td>
                            <span class="status-pill @(stockMovement.MovementType == "In" ? "success" : "warning")">
                                @(stockMovement.MovementType == "In" ? "Giriş" : "Çıkış")
                            </span>
                        </td>
                        <td>@stockMovement.Quantity</td>
                        <td>@stockMovement.Description</td>
                        <td>@stockMovement.MovementDate.ToShortDateString()</td>
                        <td class="text-end">
                            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteStockMovementModal-@stockMovement.Id">Sil</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="createStockMovementModal" tabindex="-1" aria-labelledby="createStockMovementModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="createStockMovementModalLabel">Yeni Stok Hareketi</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="stockMovementCreateProduct" class="form-label">Ürün</label>
                        <select id="stockMovementCreateProduct" name="ProductId" class="form-select">
                            <option value="">Ürün seçin</option>
                            @foreach (SelectListItem product in ViewBag.Products)
                            {
                                <option value="@product.Value">@product.Text</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="stockMovementCreateType" class="form-label">Hareket Tipi</label>
                        <select id="stockMovementCreateType" name="MovementType" class="form-select">
                            <option value="">Hareket tipi seçin</option>
                            @foreach (SelectListItem movementType in ViewBag.MovementTypes)
                            {
                                <option value="@movementType.Value">@movementType.Text</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="stockMovementCreateQuantity" class="form-label">Miktar</label>
                        <input id="stockMovementCreateQuantity" name="Quantity" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label for="stockMovementCreateDescription" class="form-label">Açıklama</label>
                        <textarea id="stockMovementCreateDescription" name="Description" class="form-control"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@foreach (var stockMovement in Model)
{
    <div class="modal fade" id="deleteStockMovementModal-@stockMovement.Id" tabindex="-1" aria-labelledby="deleteStockMovementModalLabel-@stockMovement.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="Delete" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title" id="deleteStockMovementModalLabel-@stockMovement.Id">Stok Hareketi Sil</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="id" value="@stockMovement.Id" />
                        <p class="mb-1">Bu stok hareketini silmek istediğinize emin misiniz?</p>
                        <strong>@stockMovement.Product?.Name - @(stockMovement.MovementType == "In" ? "Giriş" : "Çıkış") / @stockMovement.Quantity</strong>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                        <button type="submit" class="btn btn-danger">Sil</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
