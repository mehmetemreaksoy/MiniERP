@model List<Product>

@{
    ViewData["Title"] = "Pasif Ürünler";
}

<div class="list-page-header justify-content-end">
    <a asp-action="Index" class="btn btn-outline-secondary">Aktif Ürünlere Dön</a>
</div>

<div class="panel-card">
    <div class="table-responsive">
        <table class="table erp-table mb-0">
            <thead>
                <tr>
                    <th>Ürün Adı</th>
                    <th>Kategori</th>
                    <th>Fiyat</th>
                    <th>Stok</th>
                    <th>Silinme Tarihi</th>
                    <th class="text-end">İşlem</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="empty-state">Pasif ürün bulunamadı.</td>
                    </tr>
                }
                else
                {
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td><strong>@product.Name</strong></td>
                            <td>@product.Category?.Name</td>
                            <td>@product.Price.ToString("N2")</td>
                            <td>@product.StockQuantity</td>
                            <td>@product.DeletedDate?.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-end">
                                <form asp-action="Restore" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@product.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">Aktifleştir</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
