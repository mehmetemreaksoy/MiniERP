@model List<Customer>

@{
    ViewData["Title"] = "Cariler";
}

<div class="list-page-header">
    <div>
        <span class="panel-label">Cari Yönetimi</span>
        <h2>Cariler</h2>
        <p>Müşteri ve firma bilgilerini tek ekrandan yönetin.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Yeni Ekle</a>
</div>

<div class="panel-card">
    <div class="table-responsive">
        <table class="table erp-table mb-0">
            <thead>
                <tr>
                    <th>Cari Adı</th>
                    <th>E-posta</th>
                    <th>Telefon</th>
                    <th>Adres</th>
                    <th>Oluşturma Tarihi</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var customer in Model)
                {
                    <tr>
                        <td><strong>@customer.Name</strong></td>
                        <td>@customer.Email</td>
                        <td>@customer.Phone</td>
                        <td>@customer.Address</td>
                        <td>@customer.CreatedDate.ToShortDateString()</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@customer.Id" class="btn btn-sm btn-outline-primary">Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@customer.Id" class="btn btn-sm btn-outline-danger">Sil</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
