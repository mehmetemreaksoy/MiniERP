@model List<Sale>

@{
    ViewData["Title"] = "Satışlar";
}

<div class="list-page-header">
    <div>
        <span class="panel-label">Satış Yönetimi</span>
        <h2>Satışlar</h2>
        <p>Müşteri bazlı ürün satışlarını ve toplam tutarları görüntüleyin.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Yeni Ekle</a>
</div>

<div class="panel-card">
    <div class="table-responsive">
        <table class="table erp-table mb-0">
            <thead>
                <tr>
                    <th>Cari</th>
                    <th>Ürün</th>
                    <th>Miktar</th>
                    <th>Birim Fiyat</th>
                    <th>Toplam Tutar</th>
                    <th>Satış Tarihi</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sale in Model)
                {
                    <tr>
                        <td><strong>@sale.Customer?.Name</strong></td>
                        <td>@sale.Product?.Name</td>
                        <td>@sale.Quantity</td>
                        <td>@sale.UnitPrice.ToString("N2")</td>
                        <td><strong>@sale.TotalPrice.ToString("N2")</strong></td>
                        <td>@sale.SaleDate.ToShortDateString()</td>
                        <td class="text-end">
                            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteSaleModal-@sale.Id">Sil</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@foreach (var sale in Model)
{
    <div class="modal fade" id="deleteSaleModal-@sale.Id" tabindex="-1" aria-labelledby="deleteSaleModalLabel-@sale.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="Delete" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title" id="deleteSaleModalLabel-@sale.Id">Satış Sil</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="id" value="@sale.Id" />
                        <p class="mb-1">Bu satış kaydını silmek istediğinize emin misiniz?</p>
                        <strong>@sale.Customer?.Name - @sale.Product?.Name / @sale.TotalPrice.ToString("N2")</strong>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                        <button type="submit" class="btn btn-danger">Sil</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
